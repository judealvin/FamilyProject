{
  "name": "todo-app",
  "version": "1.0.0",
  "description": "A beginner-friendly Todo application for intern training",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:css\" \"npm run dev:js\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:css": "tailwindcss -i src/client/styles/main.css -o public/styles/main.css --watch",
    "dev:js": "node scripts/build-client.mjs --watch",
    "build": "npm run build:css && npm run build:js",
    "build:css": "tailwindcss -i src/client/styles/main.css -o public/styles/main.css --minify",
    "build:js": "node scripts/build-client.mjs",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.client.json --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "test": "node --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.6.1",
    "express": "^4.21.0",
    "express-session": "^1.18.0",
    "nodemailer": "^6.9.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.16",
    "concurrently": "^9.0.0",
    "esbuild": "^0.24.0",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
